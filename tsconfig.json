{
  "extends": "@voxpelli/tsconfig/node22.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": [
    "types/**/*",
    "lib/**/*",
    "bin/**/*",
    "fixtures/**/*",
    "test/**/*",
    "eslint.config.js"
  ],
  "exclude": ["node_modules"]
}
